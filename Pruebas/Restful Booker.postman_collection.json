                  "const schema = { \r",
                  "    type: \"object\", \r",
                  "    properties: { firstname: { \r",
                  "        type: \"string\" }, \r",
                  "        lastname: { type: \"string\" }, \r",
                  "        totalprice: { type: \"number\" },\r",
                  "        depositpaid: { type: \"boolean\" }, \r",
                  "        bookingdates: { \r",
                  "            type: \"object\", \r",
                  "            properties: { \r",
                  "                checkin: { type: \"string\" }, \r",
                  "                checkout: { type: \"string\" } \r",
                  "                }, \r",
                  "                required: [\"checkin\", \"checkout\"] \r",
                  "            }, \r",
                  "            additionalneeds: { type: \"string\" } \r",
                  "            }, \r",
                  "            required: [ \r",
                  "                \"firstname\", \r",
                  "                \"lastname\", \r",
                  "                \"totalprice\", \r",
                  "                \"depositpaid\", \r",
                  "                \"bookingdates\" \r",
                  "            ] \r",
                  "        }; \r",
                  "pm.test(\"Schema Booking válido\", function () { pm.response.to.have.jsonSchema(schema); \r",
